{
  "name": "@ecommerce/mfes",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nx run-many -t dev --parallel",
    "dev:host": "nx run @ecommerce/host:dev",
    "dev:auth": "nx run @ecommerce/auth:dev",
    "dev:products": "nx run @ecommerce/products:dev",
    "dev:orders": "nx run @ecommerce/orders:dev",
    "build": "nx run-many -t build",
    "build:all": "npm run build && npm run build:copy",
    "build:copy": "powershell Copy-Item -Path 'apps/auth/dist/*' -Destination 'apps/host/dist/' -Recurse -Force -ErrorAction SilentlyContinue; Copy-Item -Path 'apps/products/dist/*' -Destination 'apps/host/dist/' -Recurse -Force -ErrorAction SilentlyContinue; Copy-Item -Path 'apps/orders/dist/*' -Destination 'apps/host/dist/' -Recurse -Force -ErrorAction SilentlyContinue",
    "build:shared": "nx run-many -t build --projects=@ecommerce/shared,@ecommerce/shared-ui",
    "serve:prod": "nx serve @ecommerce/host --port 3000",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "nx run-many -t lint",
    "storybook": "nx run-many -t storybook"
  },
  "devDependencies": {
    "@module-federation/vite": "~1.13.0",
    "@nx/eslint": "latest",
    "@nx/js": "latest",
    "@nx/react": "latest",
    "@nx/storybook": "^22.6.1",
    "@nx/vite": "latest",
    "@nx/workspace": "latest",
    "@storybook/addon-essentials": "~8.6.0",
    "@storybook/react-vite": "~8.6.0",
    "@storybook/test": "~8.6.0",
    "@testing-library/jest-dom": "~6.6.0",
    "@testing-library/react": "~16.0.0",
    "@testing-library/user-event": "~14.5.0",
    "@types/react": "~18.3.0",
    "@types/react-dom": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "~8.0.0",
    "@typescript-eslint/parser": "~8.0.0",
    "@vitejs/plugin-react": "~4.3.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "~10.4.0",
    "concurrently": "~9.0.0",
    "eslint": "~9.0.0",
    "jsdom": "~25.0.0",
    "msw": "~2.5.0",
    "nx": "latest",
    "playwright": "^1.58.2",
    "postcss": "~8.4.0",
    "storybook": "~8.6.0",
    "tailwindcss": "~3.4.0",
    "typescript": "~5.6.0",
    "vite": "~6.0.0",
    "vitest": "~2.1.0"
  },
  "dependencies": {
    "@hookform/resolvers": "~3.9.0",
    "@radix-ui/react-label": "~2.1.0",
    "@radix-ui/react-slot": "~1.1.0",
    "@tanstack/react-query": "~5.60.0",
    "axios": "~1.7.0",
    "class-variance-authority": "~0.7.0",
    "clsx": "~2.1.0",
    "lucide-react": "~0.460.0",
    "react": "~18.3.0",
    "react-dom": "~18.3.0",
    "react-hook-form": "~7.53.0",
    "react-router-dom": "~7.0.0",
    "tailwind-merge": "~2.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "~3.23.0",
    "zustand": "~5.0.0"
  }
}
