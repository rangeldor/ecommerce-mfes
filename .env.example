# ==============================================
# BACKEND API URLs (Node.js/Express Microservices)
# These are your actual backend services
# Use 127.0.0.1 instead of localhost on Windows to avoid IPv6 issues
# ==============================================
VITE_AUTH_API_URL=http://127.0.0.1:3001
VITE_PRODUCTS_API_URL=http://127.0.0.1:3002
VITE_ORDERS_API_URL=http://127.0.0.1:3003

# ==============================================
# FRONTEND APP URLS (Microfrontend Dev Servers)
# These are the Vite dev servers for each MFE
# ==============================================
VITE_HOST_URL=http://localhost:3000
VITE_AUTH_URL=http://localhost:3005
VITE_PRODUCTS_URL=http://localhost:3006
VITE_ORDERS_URL=http://localhost:3007

# ==============================================
# NOTE: 
# - Ports 3001-3003: Your backend microservices (Node/Express)
# - Ports 3005-3007: Your frontend microfrontends (Vite dev servers)
# - Port 3000: Your host/shell application
# ==============================================
