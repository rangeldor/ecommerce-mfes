{
  "name": "@ecommerce/products",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/products/src",
  "projectType": "application",
  "implicitDependencies": ["@ecommerce/shared"],
  "targets": {
    "dev": {
      "executor": "@nx/vite:dev-server",
      "options": {
        "buildTarget": "@ecommerce/products:build",
        "port": 3006
      },
      "dependsOn": ["^build"]
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "configFile": "apps/products/vite.config.ts",
        "outputPath": "dist/apps/products"
      }
    },
    "preview": {
      "executor": "@nx/vite:preview"
    },
    "test": {
      "executor": "@nx/vite:test"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@nx/storybook:storybook",
      "options": {
        "configDir": "apps/products/.storybook",
        "devServerTarget": "@ecommerce/products:dev"
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@nx/storybook:build",
      "outputs": ["{options.outputDir}"],
      "options": {
        "configDir": "apps/products/.storybook",
        "outputDir": "dist/storybook/products"
      }
    }
  },
  "tags": []
}
